# Shared
CONVEX_URL=
NEXT_PUBLIC_CONVEX_URL=

# WorkOS AuthKit (web)
WORKOS_API_KEY=
WORKOS_CLIENT_ID=
WORKOS_COOKIE_PASSWORD=
WORKOS_REDIRECT_URI=http://localhost:3000/auth/callback
NEXT_PUBLIC_WORKOS_REDIRECT_URI=http://localhost:3000/auth/callback

# Convex deployment
# For the web app, keep CONVEX_URL and NEXT_PUBLIC_CONVEX_URL pointed at the same deployment
# to avoid the browser and auth callback writing to different Convex environments.
CONVEX_DEPLOYMENT=
BOOTSTRAP_SECRET=

# Email + notifications
EMAIL_FROM="Awn <onboarding@resend.dev>"
RESEND_API_KEY=
RESEND_WEBHOOK_SECRET=
RESEND_TEST_MODE=true

# Convex R2 component
R2_TOKEN=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ENDPOINT=
R2_BUCKET=

# Expo
EXPO_PUBLIC_CONVEX_URL=
EXPO_PUBLIC_WORKOS_CLIENT_ID=
EXPO_PUBLIC_WORKOS_API_BASE_URL=https://api.workos.com
EXPO_PUBLIC_WORKOS_PROVIDER=authkit
EXPO_PUBLIC_WORKOS_SCREEN_HINT=sign-in
EXPO_PUBLIC_WORKOS_REDIRECT_SCHEME=awn
